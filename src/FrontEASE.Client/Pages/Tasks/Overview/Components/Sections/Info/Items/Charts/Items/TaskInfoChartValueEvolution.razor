@using ApexCharts

@inject ITaskChartManipulationService taskChartManipulationService
@inject IResourceHandler resourceHandler


<ApexChart @ref="Chart" TItem="ChartDataPoint" Options="@Options">
    <ApexPointSeries TItem="ChartDataPoint"
                     Items="Data"
                     SeriesType="SeriesType.Area"
                     Name="@seriesName"
                     XValue="@(e => e.Label)"
                     YAggregate="@(e => e.Sum(x => x.Value))" />
</ApexChart>

@code {
    [Parameter]
    public TaskModalContext TaskModalContext { get; set; } = null!;

    private IList<ChartDataPoint> Data = [];
    private ApexChart<ChartDataPoint>? Chart;
    private ApexChartOptions<ChartDataPoint> Options = new();

    private string seriesName = string.Empty;
    private bool needsRedraw;
    private int lastSolutionCount;

    protected override void OnInitialized()
    {
        var titleText = resourceHandler.GetResource($"{UIConstants.Data}.{UIConstants.Specific}.{UIElementConstants.Chart}.{UITaskChartConstants.FitnessEvolutionChart}.{UIStateConstants.Explanation}");
        var subtitleText = resourceHandler.GetResource($"{UIConstants.Data}.{UIConstants.Specific}.{UIElementConstants.Chart}.{UITaskChartConstants.FitnessEvolutionChart}");
        Options = taskChartManipulationService.PrepareLineChartOptions(titleText, subtitleText);

        seriesName = resourceHandler.GetResource(AttributeExtensions.GetResourceFieldValue<TaskSolutionDto>(nameof(TaskSolutionDto.Fitness), PropertyDisplayResourceType.FIELD));
    }

    protected override Task OnParametersSetAsync()
    {
        var currentCount = TaskModalContext.Task.Solutions.Count;
        if (currentCount != lastSolutionCount)
        {
            lastSolutionCount = currentCount;
            RecalculateValues();
            needsRedraw = true;
        }
        return base.OnParametersSetAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && needsRedraw && Chart is not null)
        {
            needsRedraw = false;
            await Chart.UpdateSeriesAsync(true);
        }
    }

    private void RecalculateValues()
    {
        var messageIDs = TaskModalContext.Task.Messages.OrderBy(x => x.DateCreated).Select(x => x.ID).ToList();
        var solutionsOrdered = TaskModalContext.Task.Solutions.OrderBy(s => messageIDs.IndexOf(s.TaskMessageID)).ToList();
        Data = taskChartManipulationService.GetValueEvolutionChartData(TaskModalContext.Task.Messages, solutionsOrdered);
    }
}
