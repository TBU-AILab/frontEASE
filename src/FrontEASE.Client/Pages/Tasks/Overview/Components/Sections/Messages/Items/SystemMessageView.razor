<Container Fluid>
    <Row>
        <Column ColumnSize="ColumnSize.IsFull" TextAlignment="TextAlignment.Start" Padding="Padding.Is0">
            <Card Border="Border.Rounded" Class="border-custom-light">
                <MessageViewHeader />

                <CardBody Class="throws-shadow bg-custom-primary" Border="Border.Is0">
                    @if (!string.IsNullOrWhiteSpace(Message.Content))
                    {
                        @switch (PageContext.LoggedInUser.UserPreferences.GeneralOptions.SystemMessageDisplayFormat)
                        {
                            case MessageDisplayFormat.MARKDOWN:

                                @((MarkupString)Markdig.Markdown.ToHtml(Message.Content))
                                break;
                            case MessageDisplayFormat.PLAINTEXT:
                            default:
                                <Text>
                                    @Message.Content
                                </Text>
                                break;
                        }
                    }
                </CardBody>

                <MessageViewFooter />
            </Card>
        </Column>
    </Row>

</Container>

@code {
    [CascadingParameter]
    public TasksPageContext PageContext { get; set; } = null!;

    [Parameter]
    public TaskMessageDto Message { get; set; } = new();
}
