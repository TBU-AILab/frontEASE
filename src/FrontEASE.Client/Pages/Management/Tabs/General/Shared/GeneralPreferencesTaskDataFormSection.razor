@inject IResourceHandler resourceHandler
@inject IManagementManipulationService managementManipulationService

<Container Fluid Border="Border.Is1.Rounded" Shadow="Shadow.Small" Class="border-custom-light" Padding="Padding.Is3.FromBottom">
    <Row>
        <Column ColumnSize="ColumnSize.IsFull">
            <Container Fluid>
                <FormSectionHeader DisplayText="@(resourceHandler.GetResource($"{AttributeExtensions.GetResourceFieldValue<UserPreferencesDto>(nameof(UserPreferencesDto.GeneralOptions), PropertyDisplayResourceType.FIELD)}.{ManagementMetadataConstants.Tasks}"))" />
            </Container>
        </Column>

        <Divider Class="divider-section bg-custom-light" Shadow="Shadow.Small" />

        <Column ColumnSize="ColumnSize.Is12" Padding="Padding.Is3.FromTop">
            <Container Fluid>
                <Row>
                    <Fields>
                        <Validation>
                            <Field ColumnSize="@(FullWidthFields ? ColumnSize.IsFull : ColumnSize.Is6.OnWidescreen)">
                                <FieldLabel For="@(GetElementIdByOperation(nameof(UserPreferenceGeneralOptionsDto.UserMessageDisplayFormat)))" RequiredIndicator>
                                    @(resourceHandler.GetResource(AttributeExtensions.GetResourceFieldValue<UserPreferenceGeneralOptionsDto>(nameof(UserPreferenceGeneralOptionsDto.UserMessageDisplayFormat), PropertyDisplayResourceType.FIELD)))
                                </FieldLabel>
                                <Select @bind-Value="@GeneralPreferencesModel.UserMessageDisplayFormat" ElementId="@(GetElementIdByOperation(nameof(UserPreferenceGeneralOptionsDto.UserMessageDisplayFormat)))">
                                    <ChildContent>
                                        @foreach (var formatOption in Enum.GetValues(typeof(MessageDisplayFormat)))
                                        {
                                            <SelectItem TValue="MessageDisplayFormat" Value="@((MessageDisplayFormat)formatOption)">
                                                @(resourceHandler.GetResource(((MessageDisplayFormat)formatOption).GetEnumResourceValue()))
                                            </SelectItem>
                                        }
                                    </ChildContent>
                                    <Feedback>
                                        <ValidationError Multiline="true" />
                                    </Feedback>
                                </Select>
                            </Field>
                        </Validation>

                        <Validation>
                            <Field ColumnSize="@(FullWidthFields ? ColumnSize.IsFull : ColumnSize.Is6.OnWidescreen)">
                                <FieldLabel For="@(GetElementIdByOperation(nameof(UserPreferenceGeneralOptionsDto.SystemMessageDisplayFormat)))" RequiredIndicator>
                                    @(resourceHandler.GetResource(AttributeExtensions.GetResourceFieldValue<UserPreferenceGeneralOptionsDto>(nameof(UserPreferenceGeneralOptionsDto.SystemMessageDisplayFormat), PropertyDisplayResourceType.FIELD)))
                                </FieldLabel>
                                <Select @bind-Value="@GeneralPreferencesModel.SystemMessageDisplayFormat" ElementId="@(GetElementIdByOperation(nameof(UserPreferenceGeneralOptionsDto.SystemMessageDisplayFormat)))">
                                    <ChildContent>
                                        @foreach (var formatOption in Enum.GetValues(typeof(MessageDisplayFormat)))
                                        {
                                            <SelectItem TValue="MessageDisplayFormat" Value="@((MessageDisplayFormat)formatOption)">
                                                @(resourceHandler.GetResource(((MessageDisplayFormat)formatOption).GetEnumResourceValue()))
                                            </SelectItem>
                                        }
                                    </ChildContent>
                                    <Feedback>
                                        <ValidationError Multiline="true" />
                                    </Feedback>
                                </Select>
                            </Field>
                        </Validation>

                        <Field ColumnSize="ColumnSize.IsFull">
                            <FieldLabel For="@(GetElementIdByOperation(nameof(UserPreferenceGeneralOptionsDto.TaskGridColumns)))" RequiredIndicator>
                                @(resourceHandler.GetResource(AttributeExtensions.GetResourceFieldValue<UserPreferenceGeneralOptionsDto>(nameof(UserPreferenceGeneralOptionsDto.TaskGridColumns), PropertyDisplayResourceType.FIELD)))
                            </FieldLabel>
                            <Dropdown Class="dropdown-full-width">
                                <DropdownToggle Color="Color.Primary">
                                    @(resourceHandler.GetResource(AttributeExtensions.GetResourceFieldValue<UserPreferenceGeneralOptionsDto>(nameof(UserPreferenceGeneralOptionsDto.TaskGridColumns), PropertyDisplayResourceType.PLACEHOLDER)))
                                </DropdownToggle>
                                <DropdownMenu Class="dropdown-menu-full-width">
                                    @foreach (var columnOption in taskGridColumnsOptions)
                                    {
                                        <DropdownItem Class="dropdown-menu-item-full-width"
                                                      ShowCheckbox
                                                      CloseParentDropdowns="false"
                                                      Checked="@(GeneralPreferencesModel.TaskGridColumns?.Any(x => x.Column == columnOption) ?? false)"
                                                      CheckedChanged="@(isChecked => managementManipulationService.SyncTaskGridColumn(GeneralPreferencesModel, columnOption, isChecked))">
                                            @(resourceHandler.GetResource(columnOption.GetEnumResourceValue()))
                                        </DropdownItem>
                                    }
                                </DropdownMenu>
                            </Dropdown>
                        </Field>
                    </Fields>
                </Row>
            </Container>
        </Column>
    </Row>
</Container>

@code {

    [Parameter]
    public UserPreferenceGeneralOptionsDto GeneralPreferencesModel { get; set; } = new();

    [Parameter]
    public DataOperation Operation { get; set; }

    [Parameter]
    public bool FullWidthFields { get; set; }

    private readonly IReadOnlyCollection<TaskGridColumnsVisibility> taskGridColumnsOptions = Enum.GetValues<TaskGridColumnsVisibility>();

    protected override void OnParametersSet() => managementManipulationService.EnsureTaskGridColumnsModel(GeneralPreferencesModel);

    private string GetElementIdByOperation(string elementBase) => VisualisationHelper.GetElementIdByOperation<UserPreferenceGeneralOptionsDto>(elementBase, Operation, null);
}