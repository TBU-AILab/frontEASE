@inject IResourceHandler resourceHandler

<Fields>
    <Validation>
        <Field ColumnSize="ColumnSize.IsFull">
            <FieldLabel For="@(GetElementIdByOperation(nameof(UserPreferenceTagOptionDto.Tag)))" RequiredIndicator>
                @(resourceHandler.GetResource(AttributeExtensions.GetResourceFieldValue<UserPreferenceTagOptionDto>(nameof(UserPreferenceTagOptionDto.Tag), PropertyDisplayResourceType.FIELD)))
            </FieldLabel>
            <TextInput ElementId="@(GetElementIdByOperation(nameof(UserPreferenceTagOptionDto.Tag)))"
                       TextTransform="TextTransform.Uppercase"
                       Role="TextRole.Text"
                       Placeholder="@(resourceHandler.GetResource(AttributeExtensions.GetResourceFieldValue<UserPreferenceTagOptionDto>(nameof(UserPreferenceTagOptionDto.Tag), PropertyDisplayResourceType.PLACEHOLDER)))"
                       @bind-Value="@TagModel.Tag">
                <Feedback>
                    <ValidationError Multiline="true" />
                </Feedback>
            </TextInput>
        </Field>
    </Validation>
</Fields>

@code {
    [CascadingParameter]
    public ManagementPageContext PageContext { get; set; } = null!;

    [Parameter]
    public UserPreferenceTagOptionDto TagModel { get; set; } = new();

    [Parameter]
    public DataOperation Operation { get; set; }

    [Parameter]
    public bool FullWidthFields { get; set; }

    private string GetElementIdByOperation(string elementBase) => VisualisationHelper.GetElementIdByOperation<UserPreferenceTagOptionDto>(elementBase, Operation, null);
}